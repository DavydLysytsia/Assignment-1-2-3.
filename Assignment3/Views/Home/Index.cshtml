@{ ViewData["Title"] = "Dashboard"; }

<h4 class="mb-4 fw-bold">Dashboard</h4>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-primary">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalBooks</div>
                    <div>Total Books</div>
                </div>
                <i class="bi bi-book fs-1 opacity-50"></i>
            </div>
            <div class="card-footer small">@ViewBag.AvailableBooks available</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-success">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalReaders</div>
                    <div>Total Readers</div>
                </div>
                <i class="bi bi-people fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-warning">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.ActiveBorrows</div>
                    <div>Active Borrowings</div>
                </div>
                <i class="bi bi-arrow-left-right fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-danger">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.OverdueCount</div>
                    <div>Overdue</div>
                </div>
                <i class="bi bi-exclamation-triangle fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-book text-primary fs-1"></i>
                <h5 class="mt-2">Manage Books</h5>
                <p class="text-muted small">Add, edit, or remove books from the catalogue.</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Go to Books</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-people text-success fs-1"></i>
                <h5 class="mt-2">Manage Readers</h5>
                <p class="text-muted small">View and manage library member records.</p>
                <a asp-controller="Reader" asp-action="Index" class="btn btn-success">Go to Readers</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-arrow-left-right text-warning fs-1"></i>
                <h5 class="mt-2">Manage Borrowings</h5>
                <p class="text-muted small">Track book checkouts and returns.</p>
                <a asp-controller="Borrowing" asp-action="Index" class="btn btn-warning">Go to Borrowings</a>
            </div>
        </div>
    </div>
</div>
