@model Book
@{ ViewData["Title"] = "Delete Book"; }

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0 text-danger">Delete Book</h4>
</div>

<div class="card border-danger" style="max-width:500px">
    <div class="card-body">
        <p class="text-danger fw-semibold">Are you sure you want to delete this book?</p>
        <dl class="row">
            <dt class="col-sm-4">Title</dt>  <dd class="col-sm-8">@Model.Title</dd>
            <dt class="col-sm-4">Author</dt> <dd class="col-sm-8">@Model.Author</dd>
            <dt class="col-sm-4">ISBN</dt>   <dd class="col-sm-8"><code>@Model.ISBN</code></dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
