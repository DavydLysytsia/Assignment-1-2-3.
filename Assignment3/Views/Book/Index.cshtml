@model IEnumerable<Book>
@{ ViewData["Title"] = "Books"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-book me-2"></i>Books</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Book</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Title</th><th>Author</th><th>ISBN</th><th>Genre</th><th>Year</th><th>Status</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td class="fw-semibold">@book.Title</td>
                    <td>@book.Author</td>
                    <td><code>@book.ISBN</code></td>
                    <td>@book.Genre</td>
                    <td>@book.PublicationYear</td>
                    <td>
                        @if (book.IsAvailable)
                        { <span class="badge bg-success">Available</span> }
                        else
                        { <span class="badge bg-danger">Borrowed</span> }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit"    asp-route-id="@book.Id" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete"  asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No books found. <a asp-action="Create">Add one!</a></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
