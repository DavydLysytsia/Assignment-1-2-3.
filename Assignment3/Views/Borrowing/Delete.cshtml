@model Borrowing
@{ ViewData["Title"] = "Delete Borrowing"; }

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0 text-danger">Delete Borrowing</h4>
</div>

<div class="card border-danger" style="max-width:500px">
    <div class="card-body">
        <p class="text-danger fw-semibold">Are you sure you want to delete this borrowing record?</p>
        <dl class="row">
            <dt class="col-sm-5">Book</dt>   <dd class="col-sm-7">@Model.BookTitle</dd>
            <dt class="col-sm-5">Reader</dt> <dd class="col-sm-7">@Model.ReaderName</dd>
            <dt class="col-sm-5">Due Date</dt><dd class="col-sm-7">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
