@model Borrowing
@{ ViewData["Title"] = "Edit Borrowing"; }

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">Edit Borrowing</h4>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label asp-for="BookId" class="form-label fw-semibold">Book</label>
                <select asp-for="BookId" asp-items="ViewBag.Books" class="form-select"></select>
            </div>

            <div class="mb-3">
                <label asp-for="ReaderId" class="form-label fw-semibold">Reader</label>
                <select asp-for="ReaderId" asp-items="ViewBag.Readers" class="form-select"></select>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="BorrowDate" class="form-label fw-semibold"></label>
                    <input asp-for="BorrowDate" class="form-control" type="date" />
                </div>
                <div class="col mb-3">
                    <label asp-for="DueDate" class="form-label fw-semibold"></label>
                    <input asp-for="DueDate" class="form-control" type="date" />
                </div>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="ReturnDate" class="form-label fw-semibold"></label>
                    <input asp-for="ReturnDate" class="form-control" type="date" />
                </div>
                <div class="col mb-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsReturned" class="form-check-input" />
                        <label asp-for="IsReturned" class="form-check-label fw-semibold">Mark as Returned</label>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-warning">Update</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
