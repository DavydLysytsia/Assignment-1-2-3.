@model Borrowing
@{ ViewData["Title"] = "Borrowing Details"; }

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">Borrowing Details</h4>
</div>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-5">Book</dt>        <dd class="col-sm-7">@Model.BookTitle</dd>
            <dt class="col-sm-5">Reader</dt>      <dd class="col-sm-7">@Model.ReaderName</dd>
            <dt class="col-sm-5">Borrow Date</dt> <dd class="col-sm-7">@Model.BorrowDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-5">Due Date</dt>    <dd class="col-sm-7">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-5">Return Date</dt> <dd class="col-sm-7">@(Model.ReturnDate?.ToString("yyyy-MM-dd") ?? "Not yet returned")</dd>
            <dt class="col-sm-5">Status</dt>
            <dd class="col-sm-7">
                @if (Model.IsReturned)
                { <span class="badge bg-success">Returned</span> }
                else
                { <span class="badge bg-warning text-dark">Active</span> }
            </dd>
            <dt class="col-sm-5">Overdue Fee</dt> <dd class="col-sm-7">$@Model.OverdueFee.ToString("F2")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm me-2">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
    </div>
</div>
