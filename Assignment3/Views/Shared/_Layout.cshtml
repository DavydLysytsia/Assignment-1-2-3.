<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – LMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background: #1a237e; }
        .sidebar a { color: #c5cae9; text-decoration: none; display: block; padding: 10px 16px; border-radius: 6px; margin-bottom: 4px; }
        .sidebar a:hover, .sidebar a.active { background: #283593; color: #fff; }
        .sidebar .brand { color: #fff; font-size: 1.3rem; font-weight: 700; padding: 20px 16px; border-bottom: 1px solid #283593; margin-bottom: 12px; }
        .main-content { padding: 24px; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
    </style>
</head>
<body>
@{
    var username = Context.Session.GetString("Username");
}
<div class="d-flex">
    @if (username != null)
    {
        <div class="sidebar col-md-2 d-none d-md-flex flex-column p-2">
            <div class="brand"><i class="bi bi-book-half me-2"></i>LMS</div>
            <a asp-controller="Home"      asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
            <a asp-controller="Book"      asp-action="Index"><i class="bi bi-book me-2"></i>Books</a>
            <a asp-controller="Reader"    asp-action="Index"><i class="bi bi-people me-2"></i>Readers</a>
            <a asp-controller="Borrowing" asp-action="Index"><i class="bi bi-arrow-left-right me-2"></i>Borrowings</a>
            <div class="mt-auto pt-3 border-top border-secondary">
                <small class="text-secondary px-2">Logged in as <strong>@username</strong></small><br />
                <a asp-controller="Account" asp-action="Logout" class="text-danger mt-2"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
            </div>
        </div>
    }
    <div class="flex-grow-1 main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
