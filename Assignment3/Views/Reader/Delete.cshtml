@model Reader
@{ ViewData["Title"] = "Delete Reader"; }

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0 text-danger">Delete Reader</h4>
</div>

<div class="card border-danger" style="max-width:500px">
    <div class="card-body">
        <p class="text-danger fw-semibold">Are you sure you want to delete this reader?</p>
        <dl class="row">
            <dt class="col-sm-4">Name</dt>  <dd class="col-sm-8">@Model.Name</dd>
            <dt class="col-sm-4">Email</dt> <dd class="col-sm-8">@Model.Email</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
