@model IEnumerable<Reader>
@{ ViewData["Title"] = "Readers"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2"></i>Readers</h4>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i>Add Reader</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Name</th><th>Email</th><th>Phone</th><th>Member Since</th><th>Actions</th></tr>
            </thead>
            <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td class="fw-semibold">@r.Name</td>
                    <td>@r.Email</td>
                    <td>@r.PhoneNumber</td>
                    <td>@r.MemberSince.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit"    asp-route-id="@r.Id" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete"  asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">No readers found.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
